# ============================================================
# 静态站点环境变量说明
# ============================================================
#
# ⚠️  重要安全提示
#
# 本项目部署到 GitHub Pages，是纯静态站点。
# 所有代码最终都会在用户的浏览器中公开可见。
#
# Vite 环境变量规则：
# - 只有以 VITE_ 为前缀的变量会被嵌入到客户端代码中
# - 这些变量在构建后任何人都可以在浏览器中查看
# - 因此：不要在此文件中放置任何私密信息！
#
# 本项目配置通过 config.json 管理（需要公开的值），
# 不依赖运行时环境变量。
#
# ============================================================

# ── Giscus 评论系统配置 ────────────────────────────────────
# Giscus 需要公开的仓库来存储 Discussions，因此这些值是公开的
# 访问 https://giscus.app 获取你的配置值

# 仓库 (格式: username/repo)
VITE_GISCUS_REPO=your-username/your-repo

# 仓库 ID (从 giscus.app 获取)
VITE_GISCUS_REPO_ID=R_xxxxxxxxxxxxxx

# 分类名称 (如 "Announcements" 或 "Comments")
VITE_GISCUS_CATEGORY=Announcements

# 分类 ID (从 giscus.app 获取)
VITE_GISCUS_CATEGORY_ID=DIC_xxxxxxxxxxxxxx

# ── 部署路径（仅 CI / 本地 build 时）────────────────────────
# GitHub Actions：若仓库为「项目站」且使用自定义域名（站点在域名根路径，而非 /仓库名/），
# 请在仓库 Settings → Secrets and variables → Actions → Variables 新增 VITE_BASE，值为 /
# 否则构建产物会请求 /仓库名/assets/...，在自定义域名下会 404。

# ── 可选配置 ───────────────────────────────────────────────

# 映射方式 (pathname / specific / number / og:title)
# VITE_GISCUS_MAPPING=pathname

# 启用表情反应
# VITE_GISCUS_REACTIONS_ENABLED=1

# 发送 Discussion 元数据
# VITE_GISCUS_EMIT_METADATA=0

# 评论框位置 (bottom / top)
# VITE_GISCUS_INPUT_POSITION=bottom

# 语言设置
# VITE_GISCUS_LANG=zh-CN
